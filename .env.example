# Auto Code Redeemer — config. All optional; defaults shown. Empty .env works.
# Booleans: 1/true/yes/on | 0/false/no/off

# ── Storage ─────────────────────── (shown values are the source defaults) ──
# DATABASE_URL=file:./src/data
# SCHEDULER_POLL_INTERVAL_MS=10000        # default 10000, min 5000
# SCHEDULER_TIMEZONE=Asia/Kolkata         # default Asia/Kolkata

# ── Chrome ─────────────────── (none required; sensible defaults below) ──────
CHROME_EXECUTABLE_PATH=                   # auto-detected; set only if not found (e.g. /usr/bin/chromium)
CHROME_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\DebugProfile   # default; mount a volume in Docker
HEADLESS=false                            # default false; Docker: true
# CHROME_DEBUG_PORT=9222                  # default 9222

# ── Module toggles: <ID>_ENABLED (set wins, else source default) ──
# CLI_ENABLED=true                        # Docker: false (no TTY)
# TELEGRAM_ENABLED=true                   # default: on if token set
# CODE_REDEEM_ENABLED=true
# MAL_FRIEND_REQUEST_SENDER_ENABLED=true

# ── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                       # required for Telegram
