# ── Storage ───────────────────────────────────────────────────────────────────

# Base data directory.
# dev: default file:./src/data  |  prod: e.g. file:/data
DATABASE_URL=file:./src/data

# How often the scheduler checks for due tasks (ms). Min 5000. Default 60000.
# dev + prod: optional (default 10000) — applies whenever the process runs (dev and prod both start the scheduler)
SCHEDULER_POLL_INTERVAL_MS=10000

# IANA timezone for scheduled task times and display. Default Asia/Kolkata.
# dev + prod: optional (default Asia/Kolkata)
SCHEDULER_TIMEZONE=Asia/Kolkata

# ── Chrome / Puppeteer ──────────────────────────────────────────────────────

# Browser binary. Empty = auto-detect Chrome/Edge on Windows.
# dev: optional  |  prod: required in Docker — e.g. /usr/bin/chromium
CHROME_EXECUTABLE_PATH=

# Persistent profile for Hoyoverse login session.
# dev: recommended  |  prod: required — e.g. /data/chrome (mount a volume)
CHROME_USER_DATA_DIR=%LOCALAPPDATA%\Google\Chrome\DebugProfile

# Remote debugging port when attaching to an existing Chrome instance.
# dev: optional (default 9222)  |  prod: optional (unused when HEADLESS=true)
CHROME_DEBUG_PORT=9222

# Run browser without a visible window.
# dev: optional (false is easier for debugging)  |  prod: required (true)
HEADLESS=false

# ── Module toggles (bots + adapters) ────────────────────────────────────────
#
# Every bot and adapter is gated by a dynamic env key derived from its id:
#     <ID>_ENABLED   (id uppercased, non-alphanumerics -> "_")
#
# When the key is SET it wins; when UNSET the module's own source-code default
# applies. Recognized values: 1/true/yes/on and 0/false/no/off.
#
#   adapters:  cli                       -> CLI_ENABLED
#              telegram                  -> TELEGRAM_ENABLED
#   bots:      code-redeem               -> CODE_REDEEM_ENABLED
#              mal-friend-request-sender -> MAL_FRIEND_REQUEST_SENDER_ENABLED

# ── Telegram ────────────────────────────────────────────────────────────────

# Bot token from @BotFather.
# dev + prod: required when TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=